<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
    fx:controller="tn.esprit.controllers.equipe.AfficherEquipeController"
      prefHeight="720.0" prefWidth="1280.0"
    spacing="0"
    style="-fx-background-color: #0b1330;">

    <fx:include source="/Navbar.fxml"/>

    <VBox alignment="TOP_CENTER" spacing="18" style="-fx-padding: 28 36 24 36;" VBox.vgrow="ALWAYS">

        <HBox alignment="CENTER_LEFT" spacing="14">
            <VBox spacing="2">
                <Label text="Active Rosters"
                       style="-fx-font-size: 32px; -fx-font-weight: 800; -fx-text-fill: #f8fafc;"/>
                <Label text="Gérez et rejoignez les équipes esport"
                       style="-fx-font-size: 13px; -fx-text-fill: #64748b;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER" prefWidth="90" prefHeight="52"
                  style="-fx-background-color: #1e293b; -fx-background-radius: 12;">
                <Label fx:id="totalTeamsLabel" text="0"
                       style="-fx-font-size: 22px; -fx-font-weight: 800; -fx-text-fill: #a78bfa;"/>
                <Label text="TEAMS"
                       style="-fx-text-fill: #64748b; -fx-font-size: 10px; -fx-font-weight: 700;"/>
            </VBox>
            <Button text="+ Ajouter equipe" onAction="#handleAddEquipe"
                    style="-fx-background-color: #7c3aed; -fx-text-fill: white; -fx-font-size: 14px;
                           -fx-font-weight: 700; -fx-background-radius: 10; -fx-cursor: hand;
                           -fx-pref-height: 42; -fx-pref-width: 180;"/>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="12">
            <TextField fx:id="searchField" promptText="🔍  Rechercher une equipe..."
                 style="-fx-pref-width: 360; -fx-pref-height: 40;
                     -fx-background-color: #1e293b; -fx-text-fill: #e5e7eb;
                     -fx-prompt-text-fill: #64748b; -fx-background-radius: 10;
                     -fx-padding: 0 14;"/>
            <ComboBox fx:id="sortCombo"
                style="-fx-pref-width: 220; -fx-pref-height: 40;
                    -fx-background-color: #1e293b; -fx-background-radius: 10;"/>
        </HBox>

        <VBox fx:id="invitationsContainer" spacing="10"/>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background: transparent; -fx-background-color: transparent;
                           -fx-padding: 4 0 0 0;">
            <content>
                <FlowPane fx:id="cardsContainer" alignment="TOP_LEFT"
                          hgap="18" vgap="18" prefWrapLength="1200"/>
            </content>
        </ScrollPane>

        <Label fx:id="messageLabel" text="" style="-fx-text-fill: #f87171; -fx-font-size: 13px;"/>

    </VBox>
</VBox>
