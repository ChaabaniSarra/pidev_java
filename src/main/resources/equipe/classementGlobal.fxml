<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.equipe.ClassementGlobalController"
            prefHeight="620.0" prefWidth="1080.0"
            style="-fx-background-color: transparent;">

    <VBox spacing="18"
          AnchorPane.topAnchor="12" AnchorPane.leftAnchor="12"
          AnchorPane.rightAnchor="12" AnchorPane.bottomAnchor="12"
          style="-fx-background-color: rgba(8, 13, 27, 0.88); -fx-background-radius: 24; -fx-border-color: rgba(255,255,255,0.12); -fx-border-radius: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.24), 24, 0.0, 0.0, 18.0);">

        <HBox alignment="CENTER_LEFT" spacing="14">
            <VBox spacing="6">
                <Label text="Classement Global" style="-fx-text-fill: #f8fafc; -fx-font-size: 26px; -fx-font-weight: 800;" />
                <Label text="Classement des équipes basé sur les matchs terminés et le PPM." wrapText="true"
                       style="-fx-text-fill: #9ca3af; -fx-font-size: 13px;" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="8">
                <Label text="PPM FIRST" style="-fx-background-color: rgba(59, 130, 246, 0.18); -fx-text-fill: #bfdbfe; -fx-padding: 6 12; -fx-background-radius: 16; -fx-font-size: 11px; -fx-font-weight: 700;" />
                <Label text="FINISHED ONLY" style="-fx-background-color: rgba(14, 165, 233, 0.18); -fx-text-fill: #a5f3fc; -fx-padding: 6 12; -fx-background-radius: 16; -fx-font-size: 11px; -fx-font-weight: 700;" />
            </HBox>
        </HBox>

        <HBox spacing="12">
            <VBox spacing="4" style="-fx-background-color: rgba(15, 23, 42, 0.77); -fx-background-radius: 18; -fx-padding: 16; -fx-pref-width: 220;">
                <Label text="Équipes" style="-fx-text-fill: #cbd5e1; -fx-font-size: 11px; -fx-font-weight: 700; -fx-letter-spacing: 0.14em;" />
                <Label text="Toutes équipes" style="-fx-text-fill: #e2e8f0; -fx-font-size: 16px; -fx-font-weight: 800;" />
            </VBox>
            <VBox spacing="4" style="-fx-background-color: rgba(15, 23, 42, 0.77); -fx-background-radius: 18; -fx-padding: 16; -fx-pref-width: 220;">
                <Label text="Classement" style="-fx-text-fill: #cbd5e1; -fx-font-size: 11px; -fx-font-weight: 700; -fx-letter-spacing: 0.14em;" />
                <Label text="Mise à jour auto" style="-fx-text-fill: #e2e8f0; -fx-font-size: 16px; -fx-font-weight: 800;" />
            </VBox>
            <VBox spacing="4" style="-fx-background-color: rgba(15, 23, 42, 0.77); -fx-background-radius: 18; -fx-padding: 16; -fx-pref-width: 220;">
                <Label text="Champion" style="-fx-text-fill: #cbd5e1; -fx-font-size: 11px; -fx-font-weight: 700; -fx-letter-spacing: 0.14em;" />
                <Label text="Top PPM" style="-fx-text-fill: #e2e8f0; -fx-font-size: 16px; -fx-font-weight: 800;" />
            </VBox>
        </HBox>

        <TableView fx:id="rankingTable" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: rgba(19, 27, 45, 0.92); -fx-background-radius: 18; -fx-border-color: rgba(148,163,184,0.18); -fx-border-radius: 18; -fx-table-cell-border-color: rgba(148,163,184,0.12);">
            <columns>
                <TableColumn fx:id="rankCol" text="R" prefWidth="50" />
                <TableColumn fx:id="equipeCol" text="EQUIPE" prefWidth="190" />
                <TableColumn fx:id="mjCol" text="MJ" prefWidth="55" />
                <TableColumn fx:id="vCol" text="V" prefWidth="55" />
                <TableColumn fx:id="nCol" text="N" prefWidth="55" />
                <TableColumn fx:id="pCol" text="P" prefWidth="55" />
                <TableColumn fx:id="bpCol" text="BP" prefWidth="70" />
                <TableColumn fx:id="bcCol" text="BC" prefWidth="70" />
                <TableColumn fx:id="diffCol" text="DIFF" prefWidth="70" />
                <TableColumn fx:id="pointsCol" text="PTS" prefWidth="70" />
                <TableColumn fx:id="ppmCol" text="PPM" prefWidth="80" />
                <TableColumn fx:id="badgeCol" text="BADGE" prefWidth="150" />
            </columns>
        </TableView>

        <Label fx:id="messageLabel" text="" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;" />
    </VBox>
</AnchorPane>
