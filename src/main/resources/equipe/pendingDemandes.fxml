<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.equipe.PendingDemandesController"
            prefHeight="520.0" prefWidth="780.0"
            style="-fx-background-color: #0f172a;">

    <VBox spacing="12"
          AnchorPane.topAnchor="18" AnchorPane.leftAnchor="18"
          AnchorPane.rightAnchor="18" AnchorPane.bottomAnchor="18">

        <HBox>
            <Label text="Demandes Pending (Owner)"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Refresh" onAction="#handleRefresh"
                    style="-fx-background-color: #0ea5e9; -fx-text-fill: white; -fx-pref-width: 110;"/>
        </HBox>

        <TableView fx:id="pendingTable" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: #1e293b;">
            <columns>
                <TableColumn fx:id="equipeCol" text="Equipe" prefWidth="160"/>
                <TableColumn fx:id="joueurCol" text="Joueur" prefWidth="160"/>
                <TableColumn fx:id="statutCol" text="Statut" prefWidth="120"/>
                <TableColumn fx:id="createdCol" text="Créée le" prefWidth="240"/>
            </columns>
        </TableView>

        <Label text="Motif (optionnel)" style="-fx-text-fill: #94a3b8;"/>
        <TextField fx:id="motifField" promptText="Expliquer la decision"
                   style="-fx-background-color: #1e293b; -fx-text-fill: white; -fx-pref-height: 36;"/>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Rejeter" onAction="#handleReject"
                    style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-pref-width: 110;"/>
            <Button text="Accepter" onAction="#handleAccept"
                    style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-pref-width: 110;"/>
        </HBox>

        <Label fx:id="messageLabel" text="" style="-fx-font-size: 13px;"/>
    </VBox>
</AnchorPane>
