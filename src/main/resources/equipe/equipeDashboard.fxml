<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.equipe.EquipeDashboardController"
            prefHeight="700.0" prefWidth="1000.0"
            stylesheets="@equipeDashboard.css"
            style="-fx-background-color: linear-gradient(to bottom right, #0a0f1e, #111936);">

    <VBox spacing="18"
          AnchorPane.topAnchor="24" AnchorPane.leftAnchor="28"
          AnchorPane.rightAnchor="28" AnchorPane.bottomAnchor="16">

        <!-- ══ HEADER ══ -->
        <HBox alignment="CENTER_LEFT" spacing="14">
            <VBox alignment="CENTER" minWidth="46" minHeight="46" maxWidth="46" maxHeight="46"
                  style="-fx-background-color: linear-gradient(to bottom right, #7c3aed, #6d28d9);
                         -fx-background-radius: 13;">
                <Label text="🏆" style="-fx-font-size: 20px;"/>
            </VBox>
            <VBox spacing="1">
                <Label text="Equipes Management"
                       style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #f8fafc;"/>
                <Label text="Gestion complète de vos équipes esport"
                       style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="+ New Equipe" onAction="#handleNewEquipe"
                    style="-fx-background-color: linear-gradient(to right, #7c3aed, #8b5cf6);
                           -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 700;
                           -fx-background-radius: 10; -fx-cursor: hand;
                           -fx-pref-height: 40; -fx-pref-width: 155;
                           -fx-effect: dropshadow(gaussian, rgba(124,58,237,0.4), 12, 0, 0, 3);"/>
        </HBox>

        <!-- ══ STATS CARDS ROW ══ -->
        <HBox spacing="14">
            <!-- Total Equipes -->
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #151d3a; -fx-padding: 16 12;
                         -fx-background-radius: 14;
                         -fx-border-color: rgba(124,58,237,0.20); -fx-border-radius: 14; -fx-border-width: 1;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.20), 8, 0, 0, 3);">
                <Label text="📊" style="-fx-font-size: 16px;"/>
                <Label fx:id="totalEquipesLabel" text="0"
                       style="-fx-text-fill: #a78bfa; -fx-font-size: 30px; -fx-font-weight: 800;"/>
                <Label text="TOTAL EQUIPES"
                       style="-fx-text-fill: #64748b; -fx-font-size: 10px; -fx-font-weight: 700;"/>
            </VBox>
            <!-- Total Members Capacity -->
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #151d3a; -fx-padding: 16 12;
                         -fx-background-radius: 14;
                         -fx-border-color: rgba(14,165,233,0.20); -fx-border-radius: 14; -fx-border-width: 1;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.20), 8, 0, 0, 3);">
                <Label text="👥" style="-fx-font-size: 16px;"/>
                <Label fx:id="totalMembersCapLabel" text="0"
                       style="-fx-text-fill: #7dd3fc; -fx-font-size: 30px; -fx-font-weight: 800;"/>
                <Label text="CAPACITÉ TOTALE"
                       style="-fx-text-fill: #64748b; -fx-font-size: 10px; -fx-font-weight: 700;"/>
            </VBox>
            <!-- Avg Members -->
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #151d3a; -fx-padding: 16 12;
                         -fx-background-radius: 14;
                         -fx-border-color: rgba(245,158,11,0.20); -fx-border-radius: 14; -fx-border-width: 1;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.20), 8, 0, 0, 3);">
                <Label text="📈" style="-fx-font-size: 16px;"/>
                <Label fx:id="avgMembersLabel" text="0"
                       style="-fx-text-fill: #fcd34d; -fx-font-size: 30px; -fx-font-weight: 800;"/>
                <Label text="MOY. MEMBRES/EQ"
                       style="-fx-text-fill: #64748b; -fx-font-size: 10px; -fx-font-weight: 700;"/>
            </VBox>
        </HBox>

        <!-- ══ API GENERATION BAR ══ -->
        <HBox spacing="10" alignment="CENTER_LEFT"
              style="-fx-background-color: #151d3a; -fx-padding: 10 18;
                     -fx-background-radius: 12;
                     -fx-border-color: rgba(16,185,129,0.18); -fx-border-radius: 12; -fx-border-width: 1;">
            <Label text="🌐" style="-fx-font-size: 16px;"/>
            <Label text="Générer depuis API :"
                   style="-fx-text-fill: #e2e8f0; -fx-font-size: 12px; -fx-font-weight: 700;"/>
            <TextField fx:id="apiCountField" promptText="Nb"
                       prefWidth="55" prefHeight="34"
                       style="-fx-background-color: #0a0f1e; -fx-text-fill: white;
                              -fx-prompt-text-fill: #475569; -fx-background-radius: 8;
                              -fx-font-size: 12px; -fx-alignment: center;
                              -fx-border-color: rgba(124,58,237,0.3); -fx-border-radius: 8; -fx-border-width: 1;"/>
            <Button fx:id="generateApiBtn" text="⚡ Générer" onAction="#handleGenerateFromApi"
                    style="-fx-background-color: linear-gradient(to right, #7c3aed, #10b981);
                           -fx-text-fill: white; -fx-font-weight: 800;
                           -fx-font-size: 12px; -fx-pref-height: 34;
                           -fx-pref-width: 130; -fx-cursor: hand;
                           -fx-background-radius: 8;"/>
            <Label fx:id="apiStatusLabel" text=""
                   style="-fx-text-fill: #10b981; -fx-font-size: 11px; -fx-font-weight: 700;"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- ══ SEARCH / SORT ══ -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="searchField" promptText="🔍  Rechercher (nom, id...)"
                       HBox.hgrow="ALWAYS"
                       style="-fx-pref-height: 38;
                              -fx-background-color: #151d3a; -fx-text-fill: #e2e8f0;
                              -fx-prompt-text-fill: #475569; -fx-background-radius: 10;
                              -fx-padding: 0 14;
                              -fx-border-color: rgba(124,58,237,0.15); -fx-border-radius: 10; -fx-border-width: 1;"/>
            <ComboBox fx:id="sortCombo"
                      style="-fx-pref-width: 200; -fx-pref-height: 38;
                             -fx-background-color: #151d3a; -fx-background-radius: 10;"/>
        </HBox>

        <!-- ══ TABLE ══ -->
        <TableView fx:id="equipeTable" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: #151d3a; -fx-background-radius: 12;
                          -fx-border-color: rgba(124,58,237,0.12); -fx-border-radius: 12; -fx-border-width: 1;
                          -fx-table-cell-border-color: rgba(100,116,139,0.12);">
            <columns>
                <TableColumn fx:id="nomCol" text="NOM" prefWidth="280"/>
                <TableColumn fx:id="maxMembersCol" text="MAX MEMBERS" prefWidth="150"/>
                <TableColumn fx:id="logoCol" text="LOGO" prefWidth="300"/>
                <TableColumn fx:id="actionsCol" text="ACTIONS" prefWidth="180"/>
            </columns>
        </TableView>

        <!-- ══ MESSAGE ══ -->
        <Label fx:id="messageLabel" text="" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>

    </VBox>
</AnchorPane>
